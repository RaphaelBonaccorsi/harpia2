<launch>
    <arg name="harpia_home" default="$(env HOME)" doc="Defines the root directory of the project"/>

    <include file="$(find-pkg-share mavros)/launch/px4.launch.py">
        <!-- For local tests with gazebo simulation -->
        <!-- <arg name="fcu_url" value="udp://:14540@127.0.0.1:14557" /> -->
        <arg name="fcu_url" value="udp://:14540@localhost:14557" />
        <!-- For interfacing with USB telemetry -->
        <!-- <arg name="fcu_url" value="/dev/ttyUSB0:57600" /> -->
        <arg name="log_output" value="log" />
    </include>

    <node name="mission_planner_as" pkg="mission_planning" exec="mission_planner_server" output="screen" />
    <node name="mission_fault_mitigation_server" pkg="mission_fault_mitigation" exec="mission_fault_mitigation_server" output="screen" />
    <node name="mission_goal_manager_server" pkg="mission_goal_manager" exec="mission_goal_manager_server" output="screen" respawn="true" />
    <node name="path_planning_server" pkg="path_planning" exec="path_planning_server" output="screen" />

    <!-- Plansys2 nodes -->
    <node name="plansys2_problem_expert" pkg="plansys2_problem_expert" exec="problem_expert" output="screen">
        <param name="domain_path" value="$(arg harpia_home)/pddl/domain.pddl" />
        <param name="problem_path" value="$(arg harpia_home)/pddl/problem.pddl" />
    </node>

    <node name="plansys2_planner" pkg="plansys2_planner" exec="planner" output="screen">
        <param name="domain_path" value="$(arg harpia_home)/pddl/domain.pddl" />
        <param name="problem_path" value="$(arg harpia_home)/pddl/problem.pddl" />
    </node>

    <node name="plansys2_executor" pkg="plansys2_executor" exec="executor" output="screen">
        <param name="domain_path" value="$(arg harpia_home)/pddl/domain.pddl" />
    </node>

    <node name="plansys2_domain_expert" pkg="plansys2_domain_expert" exec="domain_expert" output="screen">
        <param name="domain_path" value="$(arg harpia_home)/pddl/domain.pddl" />
    </node>
</launch>
